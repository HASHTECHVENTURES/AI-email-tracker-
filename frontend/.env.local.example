NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_API_URL=http://localhost:3000
# Local dev: the browser calls this URL directly (CORS on Nest allows localhost). Long jobs (e.g. Historical Search) need this — do not use the Next rewrite for them.
# Optional: NEXT_PUBLIC_USE_LOCAL_API_PROXY=1 → same-origin /api-backend → Nest (next.config rewrites); can time out long requests.
# Production (Vercel): set to your public API origin, e.g. https://your-service.up.railway.app — no trailing slash, no placeholders
