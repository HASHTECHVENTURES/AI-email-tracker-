NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_API_URL=http://localhost:3000
# Local dev: Nest listens on :3000; the frontend uses :3001 (see frontend/package.json). From repo root, `npm run dev` runs both.
# Do not run `next dev` on :3000 while Nest also uses :3000 — use the script above or `next dev -p 3001`.
# The browser calls NEXT_PUBLIC_API_URL directly (CORS on Nest allows localhost). Long jobs (e.g. Historical Search) should not use the Next rewrite.
# Optional: NEXT_PUBLIC_USE_LOCAL_API_PROXY=1 → same-origin /api-backend → Nest (next.config rewrites); can time out long requests.
# Production (Vercel): set to your public API origin, e.g. https://your-service.up.railway.app — no trailing slash, no placeholders
