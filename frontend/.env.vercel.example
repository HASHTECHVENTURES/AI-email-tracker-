# =============================================================================
# Vercel → Project → Settings → Environment Variables
# Add for Production (and Preview if you use preview deployments).
# Values are placeholders — replace with your real Supabase + API URLs.
# =============================================================================

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Backend API origin — must be an absolute URL (include https://). No trailing slash.
# Host-only values (e.g. my-api.up.railway.app) break the browser without a scheme.
#   https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=https://YOUR_BACKEND_HOST

# Alternative name (frontend lib/api.ts accepts either):
# NEXT_PUBLIC_BACKEND_URL=https://YOUR_BACKEND_HOST
