{
  "name": "ai-email-tracker-frontend",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:turbo": "next dev -p 3001 --turbo",
    "dev:clean": "rm -rf .next-dev .next node_modules/.cache && next dev -p 3001",
    "build": "rm -rf .next && next build",
    "start": "next start -p 3001",
    "rebuild:start": "rm -rf .next .next-dev && npm run build && next start -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "next": "^15.3.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  }
}
