GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local: backend origin + /auth/google/callback. On Railway you can omit this if RAILWAY_PUBLIC_DOMAIN is set (auto: https://<domain>/auth/google/callback).
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional — run: npm run ensure-dev-user (creates/updates the dev quick-fill login; defaults match frontend)
# DEV_AUTH_EMAIL=email@gmail.com
# DEV_AUTH_PASSWORD=Hello1234@
# Optional fallback when service role is unavailable
SUPABASE_ANON_KEY=

GEMINI_API_KEY=your_gemini_api_key
INTERNAL_API_KEY=change_this_to_a_long_random_secret

# Comma-separated emails for platform operators (GET/POST /platform-admin/*). Must match the signed-in Supabase user’s email.
# These accounts skip tenant onboarding: they sign in and go to /admin only. They cannot use /auth “Finish setup” to create a company with this same email.
# Deleting a tenant company does not delete a platform operator’s Supabase login.
PLATFORM_ADMIN_EMAILS=

# Multi-tenant: UUID of your row in `companies` (required for ingestion; optional header fallback for APIs)
DEFAULT_COMPANY_ID=

# Optional — required for hourly AI report emails + SLA alerts (CEO + HEAD users in `users` table)
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
# Shown as "From" in the inbox (defaults to SMTP_USER)
SMTP_FROM="AI Auto Mail <your@gmail.com>"

# Optional
FRONTEND_URL=http://localhost:3001
# Supabase Dashboard → Auth → URL Configuration: add http://localhost:3001/auth/callback
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
